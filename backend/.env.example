# ─────────────────────────────────────────────────────────────────────────────
# Student Management System — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/studentDB?retryWrites=true&w=majority

# JWT secret — use a long, random string (min 32 chars)
JWT_SECRET=replace_with_a_very_long_random_secret_string_min_32_chars

# Server port
PORT=5000

# Environment: development | production
NODE_ENV=development

# Frontend origin for CORS (e.g. https://your-frontend.vercel.app)
# Leave as * for development to allow all origins
CLIENT_ORIGIN=*
